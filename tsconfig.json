{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": ["@types/node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@problems/*": ["./src/problems/*"]
    }
  }
}
